# Maintainer: Ahmet Durak <durakahmet049@gmail.com>
pkgname=archon-git
pkgver=r1.0000000
pkgrel=1
pkgdesc="System health monitor and optimizer with a native desktop GUI"
arch=('x86_64')
url="https://github.com/AhmetDurak/archon"
license=('MIT')
depends=('python' 'pyside6' 'python-psutil' 'pacman-contrib')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools' 'git')
provides=('archon')
conflicts=('archon')
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
    cd archon
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd archon
    python -m build --wheel --no-isolation
}

package() {
    cd archon
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Icon for the system app launcher
    install -Dm644 src/archon/assets/icon.svg \
        "$pkgdir/usr/share/pixmaps/archon.svg"

    # Desktop entry
    install -Dm644 packaging/archon.desktop \
        "$pkgdir/usr/share/applications/archon.desktop"
}
